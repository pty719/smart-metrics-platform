{
  "__inputs": [
    {
      "name": "DS_SMART_METRICS",
      "label": "Smart Metrics API",
      "description": "JSON datasource pointing at the Smart Metrics Platform API",
      "type": "datasource",
      "pluginId": "marcusolsson-json-datasource",
      "pluginName": "JSON API"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "marcusolsson-json-datasource",
      "name": "JSON API",
      "version": "0.6.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Smart Metrics Platform — overview of metrics, statistics, anomalies, and forecasts",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "Total number of metrics registered in the platform",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^total$/",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Total Metrics",
      "type": "stat",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics",
          "params": [["limit", "1"]],
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.total", "name": "total", "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "Descriptive statistics for the selected metric",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "mean"},
            "properties": [{"id": "displayName", "value": "Mean"}]
          },
          {
            "matcher": {"id": "byName", "options": "min"},
            "properties": [{"id": "displayName", "value": "Min"}]
          },
          {
            "matcher": {"id": "byName", "options": "max"},
            "properties": [{"id": "displayName", "value": "Max"}]
          },
          {
            "matcher": {"id": "byName", "options": "std_dev"},
            "properties": [{"id": "displayName", "value": "Std Dev"}]
          },
          {
            "matcher": {"id": "byName", "options": "median"},
            "properties": [{"id": "displayName", "value": "Median"}]
          }
        ]
      },
      "gridPos": {"h": 4, "w": 10, "x": 4, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Statistics — $metric_name",
      "type": "stat",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics/${metric_name}/stats",
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.mean",    "name": "mean",    "type": "number"},
            {"jsonPath": "$.data.min",     "name": "min",     "type": "number"},
            {"jsonPath": "$.data.max",     "name": "max",     "type": "number"},
            {"jsonPath": "$.data.std_dev", "name": "std_dev", "type": "number"},
            {"jsonPath": "$.data.median",  "name": "median",  "type": "number"},
            {"jsonPath": "$.data.count",   "name": "count",   "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "Number of anomalies detected for the selected metric",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 14, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^anomaly_count$/",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Anomaly Count — $metric_name",
      "type": "stat",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics/${metric_name}/anomalies",
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.anomaly_count", "name": "anomaly_count", "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "title": "Time Series",
      "type": "row"
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "Raw data points with moving average overlay for the selected metric",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "moving_average"},
            "properties": [
              {"id": "displayName", "value": "Moving Average"},
              {"id": "custom.lineWidth", "value": 3},
              {"id": "color", "fixedColor": "orange", "mode": "fixed"},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "value"},
            "properties": [
              {"id": "displayName", "value": "Raw Value"},
              {"id": "custom.fillOpacity", "value": 15}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "min", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "Raw Values + Moving Average (window=${ma_window}) — $metric_name",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics/${metric_name}/moving-average",
          "params": [["window", "${ma_window}"]],
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.data_points[*].timestamp",     "name": "Time",           "type": "time"},
            {"jsonPath": "$.data.data_points[*].value",         "name": "value",          "type": "number"},
            {"jsonPath": "$.data.data_points[*].moving_average","name": "moving_average", "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 102,
      "title": "Anomaly Detection",
      "type": "row"
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "List of detected anomalies with their timestamps and values",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "value"},
            "properties": [
              {"id": "displayName", "value": "Anomalous Value"},
              {"id": "custom.width", "value": 140},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null}
                ]
              }},
              {"id": "custom.displayMode", "value": "color-text"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "timestamp"},
            "properties": [
              {"id": "displayName", "value": "Detected At"},
              {"id": "custom.width", "value": 200}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "id": 5,
      "options": {
        "footer": {"fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Detected At"}]
      },
      "title": "Anomaly Log — $metric_name",
      "type": "table",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics/${metric_name}/anomalies",
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.anomalies[*].timestamp", "name": "timestamp", "type": "string"},
            {"jsonPath": "$.data.anomalies[*].value",     "name": "value",     "type": "number"},
            {"jsonPath": "$.data.anomalies[*].id",        "name": "id",        "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "IQR thresholds — values outside [lower, upper] are anomalies",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "none",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "id": 6,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "IQR Thresholds — $metric_name",
      "type": "gauge",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/metrics/${metric_name}/anomalies",
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.threshold_lower", "name": "Lower Bound", "type": "number"},
            {"jsonPath": "$.data.threshold_upper", "name": "Upper Bound", "type": "number"}
          ],
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "id": 103,
      "title": "Forecast",
      "type": "row"
    },
    {
      "datasource": "${DS_SMART_METRICS}",
      "description": "Linear regression forecast with 95% confidence interval. Submit a forecast task first via POST /api/v1/metrics/{name}/forecast, then enter the task_id below.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "lower_bound"},
            "properties": [
              {"id": "displayName", "value": "CI Lower (95%)"},
              {"id": "custom.lineStyle", "value": {"dash": [4, 4], "fill": "dash"}},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "fixedColor": "light-blue", "mode": "fixed"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "upper_bound"},
            "properties": [
              {"id": "displayName", "value": "CI Upper (95%)"},
              {"id": "custom.lineStyle", "value": {"dash": [4, 4], "fill": "dash"}},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "fixedColor": "light-blue", "mode": "fixed"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "value"},
            "properties": [
              {"id": "displayName", "value": "Forecast"},
              {"id": "color", "fixedColor": "purple", "mode": "fixed"},
              {"id": "custom.lineWidth", "value": 3}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 26},
      "id": 7,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "Forecast Result (task_id=${forecast_task_id})",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_SMART_METRICS}",
          "method": "GET",
          "path": "/api/v1/tasks/${forecast_task_id}",
          "headers": [["Authorization", "Bearer ${API_KEY}"]],
          "fields": [
            {"jsonPath": "$.data.result.forecast[*].timestamp",   "name": "Time",        "type": "time"},
            {"jsonPath": "$.data.result.forecast[*].value",       "name": "value",       "type": "number"},
            {"jsonPath": "$.data.result.forecast[*].lower_bound", "name": "lower_bound", "type": "number"},
            {"jsonPath": "$.data.result.forecast[*].upper_bound", "name": "upper_bound", "type": "number"}
          ],
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["smart-metrics", "api", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "description": "Name of the metric to visualise",
        "hide": 0,
        "label": "Metric Name",
        "name": "metric_name",
        "options": [],
        "query": "cpu_usage",
        "type": "textbox"
      },
      {
        "current": {"selected": false, "text": "7", "value": "7"},
        "description": "Moving average window size",
        "hide": 0,
        "label": "MA Window",
        "name": "ma_window",
        "options": [
          {"selected": false, "text": "3",  "value": "3"},
          {"selected": true,  "text": "7",  "value": "7"},
          {"selected": false, "text": "14", "value": "14"},
          {"selected": false, "text": "30", "value": "30"}
        ],
        "query": "3,7,14,30",
        "type": "custom"
      },
      {
        "current": {},
        "description": "Task ID returned by POST /api/v1/metrics/{name}/forecast",
        "hide": 0,
        "label": "Forecast Task ID",
        "name": "forecast_task_id",
        "options": [],
        "query": "",
        "type": "textbox"
      },
      {
        "current": {},
        "description": "API key for authentication (Bearer token)",
        "hide": 2,
        "label": "API Key",
        "name": "API_KEY",
        "options": [],
        "query": "dev-api-key-please-change-in-production",
        "type": "textbox"
      }
    ]
  },
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Smart Metrics Platform",
  "uid": "smart-metrics-v1",
  "version": 1,
  "weekStart": ""
}
