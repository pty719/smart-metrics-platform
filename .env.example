# Application
APP_NAME="Smart Metrics Platform"
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=metrics

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery (leave empty to reuse REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# API Authentication — CHANGE THIS IN PRODUCTION!
API_KEY=dev-api-key

# Cache TTL (seconds)
CACHE_TTL_STATS=300
CACHE_TTL_ANOMALIES=60
CACHE_TTL_MA=600
