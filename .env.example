# ============================================================
# Smart Metrics Platform — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Variables marked with [REQUIRED IN PRODUCTION] MUST be
# changed before deploying to any non-development environment.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Smart Metrics Platform"

# Set to false in production
DEBUG=false

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: "json" (production, machine-readable) | "text" (development)
LOG_FORMAT=json

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=metrics_user

# [REQUIRED IN PRODUCTION] Use a strong random password, e.g.:
#   openssl rand -hex 32
POSTGRES_PASSWORD=postgres

POSTGRES_DB=metrics

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# [REQUIRED IN PRODUCTION] Set a password for Redis.
# Leave blank only in local dev environments without network exposure.
# Must match the --requirepass value in the Redis command.
REDIS_PASSWORD=

# ── Celery ───────────────────────────────────────────────────
# Leave blank to auto-derive from REDIS_HOST/PORT/DB above.
# CELERY_BROKER_URL=redis://:yourpassword@localhost:6379/0
# CELERY_RESULT_BACKEND=redis://:yourpassword@localhost:6379/1

# Number of concurrent Celery worker processes.
# Recommended: 2–4 for CPU-bound forecast tasks.
CELERY_CONCURRENCY=4

# ── API Authentication ───────────────────────────────────────
# [REQUIRED IN PRODUCTION] Generate a strong random key:
#   openssl rand -hex 32
API_KEY=dev-api-key

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use "*" ONLY in development — never in production!
# Example: https://dashboard.example.com,https://admin.example.com
CORS_ORIGINS=*

# ── Server ───────────────────────────────────────────────────
# Number of Gunicorn/Uvicorn worker processes.
# Rule of thumb: 2 × CPU_COUNT + 1  (e.g. 5 for a 2-core server).
WORKERS=2

# ── Cache TTL (seconds) ──────────────────────────────────────
# How long computed results are cached in Redis before expiry.
CACHE_TTL_STATS=300      # Descriptive stats   — 5 minutes
CACHE_TTL_ANOMALIES=60   # Anomaly detection   — 1 minute
CACHE_TTL_MA=600         # Moving average      — 10 minutes
